{
  "expo": {
    "name": "kiranase",
    "slug": "delivery-partner-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bivha.kiranase-deliver-partner"
    },
    "android": {
      "package": "com.bivha.kiranase.partner",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "expo-web-browser",
      "expo-audio",
      "expo-video"
    ],
    "newArchEnabled": true,
    "scheme": "kiranase-deliver-partner"
  }
}