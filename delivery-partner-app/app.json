{
  "expo": {
    "name": "kiranase",
    "slug": "delivery-partner-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bivha.kiranase-deliver-partner",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.bivha.kiranase.partner",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "expo-web-browser",
      "expo-audio",
      "expo-video"
    ],
    "newArchEnabled": true,
    "scheme": "kiranase-deliver-partner",
    "extra": {
      "eas": {
        "projectId": "580aab3d-9a92-4cde-94ae-0cd1c35dcdec"
      }
    }
  }
}